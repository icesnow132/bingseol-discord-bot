<nav class="navbar">
  <a href="/" class="nav-brand">❄️ BingSeol Bot</a>
  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/dashboard">Dashboard</a>
    <% if (user) { %>
      <span class="nav-user">
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="avatar" class="nav-avatar" />
        <%= user.username %>
      </span>
      <a href="/logout" class="btn btn-sm btn-outline">Logout</a>
    <% } else { %>
      <a href="/auth/discord" class="btn btn-sm btn-primary">Login with Discord</a>
    <% } %>
  </div>
</nav>
